# Configuration — Football IQ Assistant Backend

# ─────────────────────────────────────────────────────────────
# OPENAI (optionnel)
# ─────────────────────────────────────────────────────────────
# Laisser vide ou préfixer avec "mock-" pour le mode offline TF-IDF local.
# En mode offline, le RAG fonctionne sans API externe.
# Fournir une vraie clé pour activer GPT-4o-mini et des réponses enrichies.
#
# Exemple clé réelle  : OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxx
# Exemple mode offline : OPENAI_API_KEY=mock-local-only
#
OPENAI_API_KEY=mock-local-only

# ─────────────────────────────────────────────────────────────
# SERVEUR
# ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─────────────────────────────────────────────────────────────
# SÉCURITÉ CORS
# ─────────────────────────────────────────────────────────────
# Origines autorisées séparées par des virgules (ex: https://mon-app.netlify.app,http://localhost:3000)
# Utiliser "*" en local pour tout autoriser sans restriction.
ALLOWED_ORIGINS=*

# ─────────────────────────────────────────────────────────────
# BASE DE CONNAISSANCES (chemin relatif depuis backend/)
# ─────────────────────────────────────────────────────────────
# BASE DE CONNAISSANCES (chemin relatif depuis backend/)
# ─────────────────────────────────────────────────────────────
# Par défaut, le chemin est résolu automatiquement dans config.py.
# Décommenter uniquement si vous déplacez la knowledge_base.
#
# KNOWLEDGE_BASE_DIR=../football-rag-system/data_football/knowledge_base

# ─────────────────────────────────────────────────────────────
# BASES DE DONNÉES & STOCKAGE (Qdrant & SQLite)
# ─────────────────────────────────────────────────────────────
# QDRANT_URL=:memory: (défaut local) ou http://localhost:6333
QDRANT_URL=:memory:
QDRANT_COLLECTION_NAME=football_intelligence
# SQLITE_DB_PATH=chemin/vers/parent_store.db (laissé vide par défaut pour la résolution automatique)

